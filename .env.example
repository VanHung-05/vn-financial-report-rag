# =============================================================================
# Đặt file này tại THƯ MỤC GỐC repo (cùng cấp docker-compose.yml):
#   vn-financial-report-rag/.env
#
# Copy:  cp .env.example .env
# =============================================================================

# Database
# Port 5433 = Docker map trong docker-compose.yml (tránh trùng Postgres cài sẵn trên máy ở 5432)
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5433/vnfinrag
DATABASE_URL_SYNC=postgresql://raguser:ragpass@localhost:5433/vnfinrag

# Redis
REDIS_URL=redis://localhost:6379/0

# File Storage (tùy chọn, khi upload qua Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Embedding: Ollama (local) ---
EMBEDDING_PROVIDER=ollama
# Local (./scripts/dev.sh): localhost. Docker container: host.docker.internal
OLLAMA_BASE_URL=http://localhost:11434
# Docker + Ollama trên máy host: http://host.docker.internal:11434
# Chạy trước: ollama pull bge-m3
EMBEDDING_MODEL=bge-m3
# Phải khớp model (nomic-embed-text = 768, mxbai-embed-large = 1024, bge-m3 = 1024)
EMBEDDING_DIMENSIONS=1024

# --- Chat: Gemini ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite

# OCR (tùy chọn)
OCR_PROVIDER=none

# Auto-index lần đầu (khi DB trống + chạy worker)
AUTO_SEED_ENABLED=true
# File trong samples/manifests/: public_demo.jsonl (20) hoặc initial_corpus.jsonl (200)
AUTO_SEED_MANIFEST=public_demo.jsonl
# Số báo cáo tối đa mỗi lần auto-seed (đặt 0 = không giới hạn)
AUTO_SEED_LIMIT=5
SEED_DATA_RATE_LIMIT=2

# OCR PDF scan (cần: brew install tesseract tesseract-lang)
OCR_ENABLED=true
OCR_LANG=vie+eng
OCR_DPI=200
